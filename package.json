{
  "name": "kepco-run",
  "version": "1.1.0",
  "description": "KEPCO런 - 한국전력공사 횡스크롤 러닝 게임",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "com.kepco.run",
    "productName": "KEPCO런",
    "files": [
      "index.html",
      "main.js",
      "preload.js",
      "sprites/**/*",
      "sprites_hongsi/**/*",
      "Hongsi.png",
      "powercat.png"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.games"
    },
    "win": {
      "target": "nsis"
    }
  }
}
